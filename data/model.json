  "repairable_model": {
    "metric": "steady_state_availability",
    "component_repair_field": "mu_per_h",
    "use_effective_lambda": true,
    "notes": [
      "单元件可用度可按 A = mu / (lambda + mu) 计算。",
      "系统层指标仍应依据 network_model 的成功判据进行组合。",
      "如采用 MTTR 而非 mu_per_h，应先换算 mu = 1 / MTTR。"
    ]
  },
  "hints": [
    "network_model 使用边可靠性视角：元件映射到网络边，系统成功事件定义为 source 到 target 连通。",
    "E10-E11-E14 构成跨支路桥接，避免退化为简单串并联 RBD。",
    "mission_profile.csv 继续用于计算各元件 duty，再与 components.csv 中的 lambda_per_h、mu_per_h 结合分析。"
  ]
}
