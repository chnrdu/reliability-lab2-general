      "PWR_IN",
      "EMI_OK",
      "DC_BUS",
      "CTRL_CORE",
      "SAFETY_OK",
      "ACT_GATE",
      "HOIST_PATH",
      "TROLLEY_PATH",
      "BRIDGE_LINK",
      "MOTION_OK",
      "LIMIT_OK",
      "POSITION_OK",
      "TASK_DONE"
    ],
    "edges": [
      {
        "id": "E1",
        "from": "START",
        "to": "PWR_IN",
        "component": "C1",
        "role": "main_power_in"
      },
      {
        "id": "E2",
